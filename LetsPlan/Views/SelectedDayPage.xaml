<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="LetsPlan.Views.SelectedDayPage"
    BackgroundColor="#F5F6FA">

    <ScrollView x:Name="MainScroll">

        <Grid HeightRequest="2000"
              ColumnDefinitions="60,*">

            <!-- LEFT TIME COLUMN -->
            <VerticalStackLayout Grid.Column="0"
                                 BackgroundColor="White">

                <BindableLayout.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>6 AM</x:String>
                        <x:String>7 AM</x:String>
                        <x:String>8 AM</x:String>
                        <x:String>9 AM</x:String>
                        <x:String>10 AM</x:String>
                        <x:String>11 AM</x:String>
                        <x:String>12 PM</x:String>
                        <x:String>1 PM</x:String>
                        <x:String>2 PM</x:String>
                        <x:String>3 PM</x:String>
                        <x:String>4 PM</x:String>
                        <x:String>5 PM</x:String>
                        <x:String>6 PM</x:String>
                        <x:String>7 PM</x:String>
                        <x:String>8 PM</x:String>
                        <x:String>9 PM</x:String>
                        <x:String>10 PM</x:String>
                        <x:String>11 PM</x:String>
                        
                    </x:Array>
                </BindableLayout.ItemsSource>

                <BindableLayout.ItemTemplate>
                    <DataTemplate>

                        <!-- ONE HOUR SLOT -->
                        <Grid HeightRequest="120">

                            <!-- hour text -->
                            <Label Text="{Binding}"
                                   FontSize="12"
                                   TextColor="Gray"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Start"
                                   Margin="0,4,0,0"/>

                            <!-- divider line -->
                            <BoxView HeightRequest="1"
                                     BackgroundColor="#E5E7EB"
                                     VerticalOptions="End"/>

                        </Grid>

                    </DataTemplate>
                </BindableLayout.ItemTemplate>

            </VerticalStackLayout>

            <!-- RIGHT TIMELINE AREA -->
            <AbsoluteLayout Grid.Column="1"
                            x:Name="TimelineCanvas"
                            BackgroundColor="#FAFAFA"
                            HeightRequest="2000"/>

        </Grid>

    </ScrollView>

</ContentPage>