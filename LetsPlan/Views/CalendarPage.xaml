<?xml version="1.0" encoding="utf-8" ?>
<!-- Views/CalendarPage.xaml -->
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:calendar="clr-namespace:Syncfusion.Maui.Calendar;assembly=Syncfusion.Maui.Calendar"
    x:Class="LetsPlan.Views.CalendarPage">

    <VerticalStackLayout >
        <calendar:SfCalendar x:Name="calendar" View="Month" LongPressed="OnLongPress">
            <calendar:SfCalendar.HeaderTemplate>
                <DataTemplate>
                    <Grid Background = "#987D9A">
                        <Label HorizontalOptions="Center" VerticalOptions="Center" Text="{Binding Text}" TextColor="White" FontSize="14" />
                    </Grid>
                </DataTemplate>
            </calendar:SfCalendar.HeaderTemplate>
        </calendar:SfCalendar>
        

        <Button Text="Clear Events"
                Clicked="OnClearEventClicked" />

        <CollectionView ItemsSource="{Binding Events}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Label Text="{Binding Title}" FontSize="5" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>